      setCurrentStatus(0);
      scaleAnim.setValue(0);
      Animated.spring(scaleAnim, { toValue: 1, useNativeDriver: true, tension: 80, friction: 8 }).start();
      const t1 = setTimeout(() => setCurrentStatus(1), 2000);
