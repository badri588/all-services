                onPress={() => {
                  const newAddr = { id: 'custom-' + Date.now(), label: 'New Location', address: customAddress, icon: '📍' };
                  onSelect(newAddr);
                  setAdding(false);
                  setCustomAddress('');
                  onClose();
                }}
              >
                <Text style={addr.addConfirmText}>Use This Address</Text>
              </TouchableOpacity>
            </View>
          )}
          <View style={{ height: 40 }} />
        </ScrollView>
      </View>
    </Modal>
  );
};

