                </TouchableOpacity>

                <Text style={bk.sectionLabel}>⏰ TIME SLOT</Text>
                <View style={bk.slotsGrid}>
                  {timeSlots.map(slot => (
                    <TouchableOpacity
                      key={slot.id} disabled={!slot.available}
