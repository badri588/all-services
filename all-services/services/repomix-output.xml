                    {selectedAddress ? selectedAddress.address : 'Select service location'}
                  </Text>
                  <MaterialCommunityIcons name="chevron-right" size={20} color="#ccc" />
                </TouchableOpacity>

                <Text style={bk.sectionLabel}>📝 INSTRUCTIONS (OPTIONAL)</Text>
                <TextInput
