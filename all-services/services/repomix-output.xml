          <Text style={styles.heroEmoji}>🛡️</Text>
        </View>
        <Text style={styles.heroSubtitle}>Posted by {workerName}</Text>

        <View style={styles.heroTagsRow}>
          <Tag label="FULL TIME" dark />
          <Tag label="Night Shift" dark />
          <Tag label={workerData?.location || '1.2 km'} dark />
