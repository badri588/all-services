import React, { useRef, useEffect } from "react";
import {
    View,
    Text,
    StyleSheet,
    SafeAreaView,
    StatusBar,
    Platform,
    TouchableOpacity,
    ScrollView,
    Animated,
    Image,
} from "react-native";
import { Ionicons, MaterialCommunityIcons, Feather } from "@expo/vector-icons";

const COLORS = {
    green: "#16A05D",
    greenLight: "#E5F8EF",
    text: "#111827",
    muted: "#6B7280",
    border: "#EEF0F4",
    orange: "#F59E0B",
    white: "#FFFFFF",
    bgLight: "#F9FAFB",
};

// A simple SVG-style map placeholder rendered with Views.
// In production, replace this with <MapView> from react-native-maps.
function MapPlaceholder({ providerColor = "#16A05D" }) {
    const pulse = useRef(new Animated.Value(1)).current;

    useEffect(() => {
        Animated.loop(
            Animated.sequence([
                Animated.timing(pulse, { toValue: 1.3, duration: 800, useNativeDriver: true }),
                Animated.timing(pulse, { toValue: 1, duration: 800, useNativeDriver: true }),
            ])
        ).start();
    }, []);

    return (
        <View style={mapStyles.container}>
            {/* Simulated map grid lines */}
            {[...Array(8)].map((_, i) => (
                <View
                    key={`h${i}`}
                    style={[mapStyles.gridLineH, { top: `${(i + 1) * 11}%` }]}
                />
            ))}
            {[...Array(6)].map((_, i) => (
                <View
                    key={`v${i}`}
                    style={[mapStyles.gridLineV, { left: `${(i + 1) * 14}%` }]}
                />
            ))}

            {/* Road highlights */}
            <View style={mapStyles.road1} />
            <View style={mapStyles.road2} />

            {/* Route line */}
            <View style={[mapStyles.routeLine, { borderColor: providerColor }]} />

            {/* Destination pin (home) */}
            <View style={[mapStyles.homePin, { backgroundColor: providerColor }]}>
                <Ionicons name="home" size={16} color="#fff" />
            </View>

            {/* Provider marker (scooter) */}
            <Animated.View style={[mapStyles.scooterMarker, { transform: [{ scale: pulse }] }]}>
                <View style={[mapStyles.scooterOuter, { borderColor: providerColor }]}>
                    <MaterialCommunityIcons name="motorbike" size={22} color={providerColor} />
                </View>
            </Animated.View>

            {/* ETA Popup */}
            <View style={mapStyles.etaPopup}>
                <Text style={mapStyles.etaPopupTitle}>
                    Provider is on the way
                </Text>
                <Text style={mapStyles.etaPopupSub}>ETA: 15 mins  •  2.4 km away</Text>
            </View>

            {/* Locate button */}
            <TouchableOpacity style={mapStyles.locateBtn} activeOpacity={0.85}>
                <Ionicons name="locate" size={22} color={COLORS.text} />
            </TouchableOpacity>

            {/* Google watermark placeholder */}
            <View style={mapStyles.googleWatermark}>
                <Text style={mapStyles.googleG}>
                    <Text style={{ color: "#4285F4" }}>G</Text>
                    <Text style={{ color: "#EA4335" }}>o</Text>
                    <Text style={{ color: "#FBBC05" }}>o</Text>
                    <Text style={{ color: "#4285F4" }}>g</Text>
                    <Text style={{ color: "#34A853" }}>l</Text>
                    <Text style={{ color: "#EA4335" }}>e</Text>
                </Text>
            </View>
        </View>
    );
}

const mapStyles = StyleSheet.create({
    container: {
        flex: 1,
