                  setAdding(false);
                  setCustomAddress('');
                  onClose();
                }}
              >
                <Text style={addr.addConfirmText}>Use This Address</Text>
              </TouchableOpacity>
            </View>
          )}
          <View style={{ height: 40 }} />
        </ScrollView>
      </View>
    </Modal>
  );
};

const addr = StyleSheet.create({
