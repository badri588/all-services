                  />
                  <Text
                    style={[
                      styles.roleText,
                      role === "User" ? styles.activeGoldRoleText : styles.inactiveRoleText,
                    ]}
                  >
                    User
                  </Text>
                </TouchableOpacity>
              </View>

              <Text style={styles.label}>Mobile Number</Text>
              <View style={styles.inputWrapper}>
                <Feather name="phone" size={22} color="#D7DCE5" style={styles.inputIcon} />
