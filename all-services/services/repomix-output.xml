                </TouchableOpacity>

                <TouchableOpacity
                  style={[
                    styles.roleButton,
                    role === "User" ? styles.activeRoleGold : styles.inactiveRole,
                  ]}
                  onPress={() => navigation.navigate("SignIn")}
                >
                  <Feather
                    name="user"
                    size={22}
                    color={role === "User" ? "#0B1220" : "#F0D07D"}
