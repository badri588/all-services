        <View style={{ flex: 1 }}>
          <ScrollView 
            style={styles.scrollBody} 
            contentContainerStyle={styles.scrollContent} 
            showsVerticalScrollIndicator={false}
          >
          <View style={styles.infoRow}>
            <View style={styles.infoCard}>
              <Text style={styles.infoLabel}>Base Pay</Text>
