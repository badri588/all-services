  const statuses = [
    { icon: '📋', title: 'Order Received', sub: 'Beauty network is reviewing request', done: currentStatus >= 0 },
    { icon: '✂️', title: 'Shortlisting Stylists', sub: 'Selecting the best local expert for you', done: currentStatus >= 1 },
