                  </Text>
                  <MaterialCommunityIcons name="chevron-right" size={20} color="#ccc" />
                </TouchableOpacity>

                <Text style={bk.sectionLabel}>⏰ TIME SLOT</Text>
                <View style={bk.slotsGrid}>
                  {timeSlots.map(slot => (
                    <TouchableOpacity
